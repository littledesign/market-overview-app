# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit API keys.

# Required for stock quotes (market-data, search, profile endpoints)
# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key

# Required for Weather module — get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key

# Optional — defaults to 3000
PORT=3000

# Required for AI summaries in News & Trends — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional — only needed if you use Supabase auth/saved data
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
